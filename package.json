{
  "name": "rodrigos-cli",
  "version": "2.0.0",
  "description": "Turn any script folder into a CLI",
  "bin": {
    "rc": "dist/rc.cjs"
  },
  "type": "module",
  "scripts": {
    "build": "esbuild src/bin/rc.ts --bundle --platform=node --target=node18 --outfile=dist/rc.cjs --format=cjs --banner:js='#!/usr/bin/env node'",
    "dev": "tsx src/bin/rc.ts",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && chmod +x dist/rc.js"
  },
  "keywords": [
    "cli",
    "scripts",
    "developer-tools",
    "whitelabel"
  ],
  "author": "Rodrigo Sasaki",
  "license": "MIT",
  "packageManager": "pnpm@10.13.1",
  "dependencies": {
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "esbuild": "^0.19.12",
    "eslint": "^8.56.0",
    "prettier": "^3.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
